{
  "uid": "server-security",
  "title": "服务器安全与系统",
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [
    { "name": "server", "label": "服务器", "type": "query", "datasource": { "type": "loki", "uid": "loki" }, "definition": "label_values({server=~\".+\"}, server)", "query": "label_values({server=~\".+\"}, server)", "refresh": 1, "includeAll": true, "allValue": ".*", "multi": false, "current": { "selected": true, "text": "全部", "value": "$__all" } }
  ]},
  "panels": [
    { "id": 1, "type": "stat", "title": "SSH 失败登录", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "sum(count_over_time({job=~\"ssh-journal|ssh-auth\",server=~\"$server\"} |~ \"Failed password|Invalid user|authentication failure\" [$__range]))", "instant": true }], "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 2, "type": "stat", "title": "Fail2ban 发现", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "sum(count_over_time({job=\"fail2ban\",server=~\"$server\"} |= \"] Found \" [$__range]))", "instant": true }], "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 3, "type": "stat", "title": "Fail2ban 封禁", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "sum(count_over_time({job=\"fail2ban\",server=~\"$server\"} |= \"] Ban \" [$__range]))", "instant": true }], "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 4, "type": "stat", "title": "UFW 拒绝记录", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "sum(count_over_time({job=\"ufw\",server=~\"$server\"} [$__range]))", "instant": true }], "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 5, "type": "timeseries", "title": "CPU 使用率", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "100 - (avg by (server) (rate(node_cpu_seconds_total{server=~\"$server\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{server}}" }], "gridPos": { "x": 0, "y": 5, "w": 8, "h": 8 }, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 6, "type": "timeseries", "title": "内存使用率", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "100 * (1 - node_memory_MemAvailable_bytes{server=~\"$server\"} / node_memory_MemTotal_bytes{server=~\"$server\"})", "legendFormat": "{{server}}" }], "gridPos": { "x": 8, "y": 5, "w": 8, "h": 8 }, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 7, "type": "timeseries", "title": "服务器网卡流量", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum by (server) (rate(node_network_receive_bytes_total{server=~\"$server\",device!~\"lo|docker.*|veth.*\"}[5m]))", "legendFormat": "{{server}} 下载" }, { "refId": "B", "expr": "sum by (server) (rate(node_network_transmit_bytes_total{server=~\"$server\",device!~\"lo|docker.*|veth.*\"}[5m]))", "legendFormat": "{{server}} 上传" }], "gridPos": { "x": 16, "y": 5, "w": 8, "h": 8 }, "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 8, "type": "table", "title": "SSH 失败来源 IP（按失败次数 Top 20）", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "topk(20, sum by (source_ip,geo_country,geo_region,geo_city) (count_over_time({job=~\"ssh-journal|ssh-auth\",server=~\"$server\"} |~ \"Failed password|Invalid user|authentication failure\" | regexp `from (?P<source_ip>(?:\\[[0-9A-Fa-f:]+\\]|[0-9A-Fa-f:.]+))` [$__range])))", "instant": true, "format": "table" }], "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 }, "options": { "showHeader": true, "sortBy": [{ "displayName": "失败次数", "desc": true }] }, "transformations": [{ "id": "sortBy", "options": { "sort": [{ "field": "Value #A", "desc": true }] } }, { "id": "organize", "options": { "excludeByName": {}, "indexByName": { "Time": 0, "source_ip": 1, "geo_country": 2, "geo_region": 3, "geo_city": 4, "Value #A": 5 }, "renameByName": { "Time": "时间", "source_ip": "来源 IP", "geo_country": "国家/地区", "geo_region": "省份", "geo_city": "城市", "Value #A": "失败次数" } } }] },
    { "id": 9, "type": "table", "title": "Fail2ban 封禁 IP（按封禁次数 Top 20）", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "topk(20, sum by (source_ip,geo_country,geo_region,geo_city) (count_over_time({job=\"fail2ban\",server=~\"$server\"} | regexp `\\] Ban (?P<source_ip>(?:\\[[0-9A-Fa-f:]+\\]|[0-9A-Fa-f:.]+))` [$__range])))", "instant": true, "format": "table" }], "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 }, "options": { "showHeader": true, "sortBy": [{ "displayName": "封禁次数", "desc": true }] }, "transformations": [{ "id": "sortBy", "options": { "sort": [{ "field": "Value #A", "desc": true }] } }, { "id": "organize", "options": { "excludeByName": {}, "indexByName": { "Time": 0, "source_ip": 1, "geo_country": 2, "geo_region": 3, "geo_city": 4, "Value #A": 5 }, "renameByName": { "Time": "时间", "source_ip": "封禁 IP", "geo_country": "国家/地区", "geo_region": "省份", "geo_city": "城市", "Value #A": "封禁次数" } } }] },
    { "id": 10, "type": "logs", "title": "SSH 失败与 Fail2ban 事件", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "{server=~\"$server\",job=~\"ssh-journal|ssh-auth|fail2ban\"} |~ \"Failed password|Invalid user|authentication failure|] Found |] Ban |] Unban \"" }], "gridPos": { "x": 0, "y": 29, "w": 24, "h": 9 }, "options": { "dedupStrategy": "none", "enableLogDetails": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" } }
  ]
}
