{
  "uid": "server-security",
  "title": "服务器安全事件与系统资源",
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 11,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [
    { "name": "server", "label": "服务器", "type": "query", "datasource": { "type": "loki", "uid": "loki" }, "definition": "label_values({server=~\".+\"}, server)", "query": "label_values({server=~\".+\"}, server)", "refresh": 1, "includeAll": true, "allValue": ".*", "multi": false, "current": { "selected": true, "text": "全部", "value": "$__all" } }
  ]},
  "panels": [
    { "id": 1, "type": "stat", "title": "SSH 失败登录", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "sum(count_over_time({job=~\"ssh-journal|ssh-auth\",server=~\"$server\"} |~ \"Failed password|Invalid user|authentication failure\" [$__range]))", "instant": true }], "gridPos": { "x": 0, "y": 0, "w": 5, "h": 5 }, "fieldConfig": { "defaults": { "noValue": "0" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 2, "type": "stat", "title": "Fail2ban 发现", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "sum(count_over_time({job=\"fail2ban\",server=~\"$server\"} |= \"] Found \" [$__range]))", "instant": true }], "gridPos": { "x": 5, "y": 0, "w": 5, "h": 5 }, "fieldConfig": { "defaults": { "noValue": "0" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 3, "type": "stat", "title": "Fail2ban 封禁", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "sum(count_over_time({job=\"fail2ban\",server=~\"$server\"} |= \"] Ban \" [$__range]))", "instant": true }], "gridPos": { "x": 10, "y": 0, "w": 5, "h": 5 }, "fieldConfig": { "defaults": { "noValue": "0" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 4, "type": "stat", "title": "UFW 拒绝记录", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "sum(count_over_time({job=\"ufw\",server=~\"$server\"} [$__range]))", "instant": true }], "gridPos": { "x": 15, "y": 0, "w": 5, "h": 5 }, "fieldConfig": { "defaults": { "noValue": "0" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 11, "type": "stat", "title": "指标最新时间", "description": "VictoriaMetrics 中最近一条主机指标的写入时间。未启用主机指标的采集端会显示“无指标数据”。", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "1000 * max(timestamp(node_time_seconds{server=~\"$server\"}))", "instant": true }], "gridPos": { "x": 20, "y": 0, "w": 4, "h": 5 }, "fieldConfig": { "defaults": { "unit": "dateTimeAsLocal", "noValue": "无指标数据" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "none", "justifyMode": "auto" } },
    { "id": 12, "type": "table", "title": "最近 20 次 SSH 失败记录", "description": "按事件时间倒序展示最新 20 条 SSH 认证失败。来源端口是客户端发起连接时使用的端口，不是服务器的 SSH 监听端口。", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "{job=~\"ssh-journal|ssh-auth\",server=~\"$server\"} |~ \"Failed password|Invalid user\" | regexp `(?:Failed password for (?:invalid user )?|Invalid user )(?P<attempted_user>\\S+) from (?P<source_ip>(?:\\[[0-9A-Fa-f:]+\\]|[0-9A-Fa-f:.]+)) port (?P<source_port>[0-9]+)` | attempted_user != \"\" | line_format `来源 IP: {{ .source_ip }} | 国家/地区: {{ .geo_country }} | 省份: {{ .geo_region }} | 城市: {{ .geo_city }} | 尝试用户名: {{ .attempted_user }} | 来源端口: {{ .source_port }}`", "maxLines": 20 }], "gridPos": { "x": 0, "y": 5, "w": 24, "h": 10 }, "fieldConfig": { "defaults": {}, "overrides": [{ "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.width", "value": 180 }] }, { "matcher": { "id": "byName", "options": "source_ip" }, "properties": [{ "id": "custom.width", "value": 160 }, { "id": "custom.align", "value": "left" }] }, { "matcher": { "id": "byName", "options": "attempted_user" }, "properties": [{ "id": "custom.width", "value": 140 }, { "id": "custom.align", "value": "left" }] }, { "matcher": { "id": "byName", "options": "source_port" }, "properties": [{ "id": "custom.width", "value": 110 }, { "id": "custom.align", "value": "center" }] }] }, "options": { "showHeader": true, "sortBy": [{ "displayName": "时间", "desc": true }] }, "transformations": [{ "id": "extractFields", "options": { "source": "NewField", "format": "regexp", "regexp": "来源 IP: (?<source_ip>[^|]+) \\| 国家/地区: (?<geo_country>[^|]*) \\| 省份: (?<geo_region>[^|]*) \\| 城市: (?<geo_city>[^|]*) \\| 尝试用户名: (?<attempted_user>[^|]+) \\| 来源端口: (?<source_port>[0-9]+)" } }, { "id": "sortBy", "options": { "sort": [{ "field": "Time", "desc": true }] } }, { "id": "organize", "options": { "excludeByName": { "NewField": true, "labelTypes": true, "id": true, "Line": true, "labels": true, "tsNs": true }, "indexByName": { "Time": 0, "source_ip": 1, "geo_country": 2, "geo_region": 3, "geo_city": 4, "attempted_user": 5, "source_port": 6 }, "renameByName": { "Time": "时间", "source_ip": "来源 IP", "geo_country": "国家/地区", "geo_region": "省份", "geo_city": "城市", "attempted_user": "尝试用户名", "source_port": "来源端口" } } }] },
    { "id": 5, "type": "timeseries", "title": "CPU 使用率", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "100 - (avg by (server) (rate(node_cpu_seconds_total{server=~\"$server\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{server}}" }], "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 }, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 6, "type": "timeseries", "title": "内存使用率", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "100 * (1 - node_memory_MemAvailable_bytes{server=~\"$server\"} / node_memory_MemTotal_bytes{server=~\"$server\"})", "legendFormat": "{{server}}" }], "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 }, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 7, "type": "timeseries", "title": "服务器网卡流量", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum by (server) (rate(node_network_receive_bytes_total{server=~\"$server\",device!~\"lo|docker.*|veth.*\"}[5m]))", "legendFormat": "{{server}} 下载" }, { "refId": "B", "expr": "sum by (server) (rate(node_network_transmit_bytes_total{server=~\"$server\",device!~\"lo|docker.*|veth.*\"}[5m]))", "legendFormat": "{{server}} 上传" }], "gridPos": { "x": 0, "y": 23, "w": 24, "h": 8 }, "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 13, "type": "timeseries", "title": "SSH 端口入站流量", "description": "统计到达 SSH 监听端口的总入站流量，包含正常 SSH 会话和扫描，不代表攻击来源的精确流量。", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum by (server) (rate(gla_ssh_inbound_bytes_total{server=~\"$server\"}[5m]))", "legendFormat": "{{server}}" }], "gridPos": { "x": 0, "y": 31, "w": 12, "h": 7 }, "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 14, "type": "timeseries", "title": "UFW 默认拒绝流量", "description": "统计未被 UFW 规则放行、最终落入默认 INPUT 拒绝策略的流量；它是防火墙聚合值，不按来源 IP 归因。", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum by (server) (rate(gla_ufw_default_denied_bytes_total{server=~\"$server\"}[5m]))", "legendFormat": "{{server}}" }], "gridPos": { "x": 12, "y": 31, "w": 12, "h": 7 }, "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 8, "type": "table", "title": "SSH 失败来源 IP（按失败次数 Top 20）", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "topk(20, sum by (source_ip,geo_country,geo_region,geo_city) (count_over_time({job=~\"ssh-journal|ssh-auth\",server=~\"$server\"} |~ \"Failed password|Invalid user|authentication failure\" | regexp `from (?P<source_ip>(?:\\[[0-9A-Fa-f:]+\\]|[0-9A-Fa-f:.]+))` | source_ip != \"\" [$__range])))", "instant": true, "format": "table" }], "gridPos": { "x": 0, "y": 38, "w": 24, "h": 9 }, "fieldConfig": { "defaults": {}, "overrides": [{ "matcher": { "id": "byName", "options": "source_ip" }, "properties": [{ "id": "custom.width", "value": 180 }, { "id": "custom.align", "value": "left" }] }, { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "custom.width", "value": 100 }, { "id": "custom.align", "value": "right" }] }] }, "options": { "showHeader": true, "sortBy": [{ "displayName": "失败次数", "desc": true }] }, "transformations": [{ "id": "sortBy", "options": { "sort": [{ "field": "Value #A", "desc": true }] } }, { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "source_ip": 0, "geo_country": 1, "geo_region": 2, "geo_city": 3, "Value #A": 4 }, "renameByName": { "source_ip": "来源 IP", "geo_country": "国家/地区", "geo_region": "省份", "geo_city": "城市", "Value #A": "失败次数" } } }] },
    { "id": 9, "type": "table", "title": "Fail2ban 封禁 IP（按封禁次数 Top 20）", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "topk(20, sum by (source_ip,geo_country,geo_region,geo_city) (count_over_time({job=\"fail2ban\",server=~\"$server\"} | regexp `\\] Ban (?P<source_ip>(?:\\[[0-9A-Fa-f:]+\\]|[0-9A-Fa-f:.]+))` | source_ip != \"\" [$__range])))", "instant": true, "format": "table" }], "gridPos": { "x": 0, "y": 47, "w": 24, "h": 9 }, "fieldConfig": { "defaults": {}, "overrides": [{ "matcher": { "id": "byName", "options": "source_ip" }, "properties": [{ "id": "custom.width", "value": 180 }, { "id": "custom.align", "value": "left" }] }, { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "custom.width", "value": 100 }, { "id": "custom.align", "value": "right" }] }] }, "options": { "showHeader": true, "sortBy": [{ "displayName": "封禁次数", "desc": true }] }, "transformations": [{ "id": "sortBy", "options": { "sort": [{ "field": "Value #A", "desc": true }] } }, { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "source_ip": 0, "geo_country": 1, "geo_region": 2, "geo_city": 3, "Value #A": 4 }, "renameByName": { "source_ip": "封禁 IP", "geo_country": "国家/地区", "geo_region": "省份", "geo_city": "城市", "Value #A": "封禁次数" } } }] },
    { "id": 10, "type": "logs", "title": "SSH 失败与 Fail2ban 事件", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "{server=~\"$server\",job=~\"ssh-journal|ssh-auth|fail2ban\"} |~ \"Failed password|Invalid user|authentication failure|] Found |] Ban |] Unban \"" }], "gridPos": { "x": 0, "y": 56, "w": 24, "h": 10 }, "options": { "dedupStrategy": "none", "enableLogDetails": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" } }
  ]
}
