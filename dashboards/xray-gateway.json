{
  "uid": "xray-gateway",
  "title": "Xray Gateway",
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [
    { "name": "server", "label": "服务器", "type": "query", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "definition": "label_values(xui_exporter_up, server)", "query": { "qry": "label_values(xui_exporter_up, server)", "refId": "VariableQueryEditor-VariableQuery" }, "refresh": 1, "includeAll": true, "allValue": ".*", "multi": false, "current": { "selected": true, "text": "全部", "value": "$__all" } }
  ]},
  "panels": [
    { "id": 1, "type": "stat", "title": "在线用户", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum(xui_client_online{server=~\"$server\"})", "instant": true }], "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" } },
    { "id": 2, "type": "stat", "title": "3x-ui API 状态", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "min(xui_exporter_up{server=~\"$server\"})", "instant": true }], "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 }, "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "不可用", "color": "red" }, "1": { "text": "正常", "color": "green" } } }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "auto" } },
    { "id": 3, "type": "stat", "title": "当前下载速率", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum(rate(xui_client_traffic_bytes_total{server=~\"$server\",direction=\"downlink\"}[5m]))", "instant": true }], "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 }, "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 4, "type": "stat", "title": "当前上传速率", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum(rate(xui_client_traffic_bytes_total{server=~\"$server\",direction=\"uplink\"}[5m]))", "instant": true }], "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 }, "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 5, "type": "timeseries", "title": "Xray 上下行流量", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum by (direction) (rate(xui_client_traffic_bytes_total{server=~\"$server\"}[5m]))", "legendFormat": "{{direction}}" }], "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 }, "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 6, "type": "table", "title": "Top Client（按当前时间范围流量）", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "topk(20, sum by (email) (increase(xui_client_traffic_bytes_total{server=~\"$server\"}[$__range])))", "instant": true, "format": "table" }], "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 }, "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }, "options": { "showHeader": true } },
    { "id": 7, "type": "table", "title": "按入站与端口流量", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum by (inbound,port,protocol) (increase(xui_inbound_traffic_bytes_total{server=~\"$server\"}[$__range]))", "instant": true, "format": "table" }], "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 }, "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }, "options": { "showHeader": true } },
    { "id": 8, "type": "table", "title": "来源 IP 连接数 Top 20", "description": "基于 Xray 访问日志统计连接次数，不代表该 IP 的精确流量。国家地图需要另行配置 GeoIP 数据库。", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "topk(20, sum by (source_ip) (count_over_time({job=\"xray-access\",server=~\"$server\"} | regexp `from (?P<source_ip>.+):[0-9]+ accepted` [$__range])))", "instant": true, "format": "table" }], "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 }, "options": { "showHeader": true } },
    { "id": 9, "type": "logs", "title": "Xray 访问日志", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "{job=\"xray-access\",server=~\"$server\"} != \"[api -> api]\"" }], "gridPos": { "x": 0, "y": 21, "w": 24, "h": 9 }, "options": { "dedupStrategy": "none", "enableLogDetails": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" } }
  ]
}
