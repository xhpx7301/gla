{
  "uid": "xray-gateway",
  "title": "Xray 网关流量与连接",
  "timezone": "Asia/Shanghai",
  "schemaVersion": 41,
  "version": 8,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [
    { "name": "server", "label": "服务器", "type": "query", "datasource": { "type": "loki", "uid": "loki" }, "definition": "label_values({server=~\".+\"}, server)", "query": "label_values({server=~\".+\"}, server)", "refresh": 1, "includeAll": true, "allValue": ".+", "multi": false, "options": [], "regex": "", "sort": 1, "current": { "selected": true, "text": "全部", "value": "$__all" } }
  ]},
  "panels": [
    { "id": 1, "type": "stat", "title": "在线用户", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum(xui_client_online{server=~\"$server\"})", "instant": true }], "gridPos": { "x": 0, "y": 0, "w": 5, "h": 5 }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" } },
    { "id": 2, "type": "stat", "title": "3x-ui API 状态", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "min(xui_exporter_up{server=~\"$server\"})", "instant": true }], "gridPos": { "x": 5, "y": 0, "w": 5, "h": 5 }, "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "不可用", "color": "red" }, "1": { "text": "正常", "color": "green" } } }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "auto" } },
    { "id": 3, "type": "stat", "title": "当前下载速率", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum(rate(xui_client_traffic_bytes_total{server=~\"$server\",direction=\"downlink\"}[5m]))", "instant": true }], "gridPos": { "x": 10, "y": 0, "w": 5, "h": 5 }, "fieldConfig": { "defaults": { "unit": "Bps", "noValue": "0 B/s" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 4, "type": "stat", "title": "当前上传速率", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum(rate(xui_client_traffic_bytes_total{server=~\"$server\",direction=\"uplink\"}[5m]))", "instant": true }], "gridPos": { "x": 15, "y": 0, "w": 5, "h": 5 }, "fieldConfig": { "defaults": { "unit": "Bps", "noValue": "0 B/s" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "area", "justifyMode": "auto" } },
    { "id": 10, "type": "stat", "title": "指标最新时间", "description": "VictoriaMetrics 中最近一条 3x-ui exporter 指标的写入时间。API 是否可用请结合“3x-ui API 状态”查看。", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "1000 * max(timestamp(xui_exporter_up{server=~\"$server\"}))", "instant": true }], "gridPos": { "x": 20, "y": 0, "w": 4, "h": 5 }, "fieldConfig": { "defaults": { "unit": "dateTimeAsLocal", "noValue": "无指标数据" }, "overrides": [] }, "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "none", "justifyMode": "auto" } },
    { "id": 5, "type": "timeseries", "title": "Xray 上下行流量", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum by (direction) (rate(xui_client_traffic_bytes_total{server=~\"$server\"}[5m]))", "legendFormat": "{{direction}}" }], "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 }, "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } } },
    { "id": 6, "type": "table", "title": "客户端流量 Top 20（按流量降序）", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "topk(20, sum by (email) (increase(xui_client_traffic_bytes_total{server=~\"$server\"}[$__range])))", "instant": true, "format": "table" }], "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 }, "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [{ "matcher": { "id": "byName", "options": "email" }, "properties": [{ "id": "custom.align", "value": "left" }] }, { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.align", "value": "right" }] }] }, "options": { "showHeader": true, "sortBy": [{ "displayName": "流量", "desc": true }] }, "transformations": [{ "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }, { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "email": 0, "Value": 1 }, "renameByName": { "email": "客户端", "Value": "流量" } } }] },
    { "id": 7, "type": "table", "title": "入站流量与端口（按流量降序）", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "targets": [{ "refId": "A", "expr": "sum by (inbound,port,protocol) (increase(xui_inbound_traffic_bytes_total{server=~\"$server\"}[$__range]))", "instant": true, "format": "table" }], "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 }, "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [{ "matcher": { "id": "byName", "options": "inbound" }, "properties": [{ "id": "custom.align", "value": "left" }] }, { "matcher": { "id": "byName", "options": "port" }, "properties": [{ "id": "unit", "value": "none" }, { "id": "decimals", "value": 0 }, { "id": "custom.align", "value": "center" }] }, { "matcher": { "id": "byName", "options": "protocol" }, "properties": [{ "id": "custom.align", "value": "center" }] }, { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.align", "value": "right" }] }] }, "options": { "showHeader": true, "sortBy": [{ "displayName": "流量", "desc": true }] }, "transformations": [{ "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }, { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "inbound": 0, "port": 1, "protocol": 2, "Value": 3 }, "renameByName": { "inbound": "入站", "port": "端口", "protocol": "协议", "Value": "流量" } } }] },
    { "id": 8, "type": "table", "title": "来源 IP 连接数 Top 20（按连接次数降序）", "description": "基于 Xray 访问日志统计连接次数，不代表该 IP 的精确流量。国家、省份和城市来自采集端本地 GeoIP 数据库；未配置数据库时这些字段为空。", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "topk(20, sum by (source_ip,geo_country,geo_region,geo_city) (count_over_time({job=\"xray-access\",server=~\"$server\"} | regexp `from (?P<source_ip>(?:\\[[0-9A-Fa-f:]+\\]|[0-9A-Fa-f:.]+)):[0-9]+ accepted` | source_ip != \"\" [$__range])))", "instant": true, "format": "table" }], "gridPos": { "x": 0, "y": 21, "w": 24, "h": 9 }, "fieldConfig": { "defaults": {}, "overrides": [{ "matcher": { "id": "byName", "options": "source_ip" }, "properties": [{ "id": "custom.width", "value": 180 }, { "id": "custom.align", "value": "left" }] }, { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "custom.width", "value": 100 }, { "id": "custom.align", "value": "right" }] }] }, "options": { "showHeader": true, "sortBy": [{ "displayName": "连接次数", "desc": true }] }, "transformations": [{ "id": "sortBy", "options": { "sort": [{ "field": "Value #A", "desc": true }] } }, { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "source_ip": 0, "geo_country": 1, "geo_region": 2, "geo_city": 3, "Value #A": 4 }, "renameByName": { "source_ip": "来源 IP", "geo_country": "国家/地区", "geo_region": "省份", "geo_city": "城市", "Value #A": "连接次数" } } }] },
    { "id": 9, "type": "logs", "title": "Xray 访问日志", "datasource": { "type": "loki", "uid": "loki" }, "targets": [{ "refId": "A", "expr": "{job=\"xray-access\",server=~\"$server\"} != \"[api -> api]\"" }], "gridPos": { "x": 0, "y": 30, "w": 24, "h": 10 }, "options": { "dedupStrategy": "none", "enableLogDetails": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" } }
  ]
}
